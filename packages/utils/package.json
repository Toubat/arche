{
  "name": "@repo/utils",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "@repo/source": "./src/index.ts",
      "bun": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc --build",
    "dev": "tsc --build --watch",
    "check-types": "tsc --noEmit",
    "clean": "rm -rf dist .turbo *.tsbuildinfo",
    "prepublishOnly": "bun run build"
  },
  "devDependencies": {
    "typescript": "^5.5.4"
  }
}
